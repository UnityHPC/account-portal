# vscode project files
.vscode/**/*
!.vscode/
!.vscode/settings-recommended.jsonc

# don't include DS_store files generated by mac os
**/.DS_store
**/.rnd

# don't track vendor files from composer
vendor

# don't track site configs
deployment/**/*
!deployment/
!deployment/domain_overrides/
!deployment/domain_overrides/worker/
!deployment/domain_overrides/worker/config.ini
!deployment/domain_overrides/course-creator/
!deployment/domain_overrides/course-creator/config.ini
!deployment/README.md
!deployment/config.base.ini
!deployment/mail/
!deployment/mail/.gitinclude
!deployment/templates/
!deployment/templates/.gitinclude

.phpunit.result.cache
.php-cs-fixer.cache
.twig-cs-fixer.cache

node_modules
# copied from node_modules using the copy-files-from-to NPM package
*.min.js
public/js/*dataTables*.js
public/css/*dataTables*.css
